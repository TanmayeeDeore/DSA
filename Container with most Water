class Solution {
    public int maxArea(int[] height) {
        int lp = 0;
        int rp = height.length-1;
        int Maxwater= 0;
        while (lp<rp){
            int w = rp - lp;
            int h = Math.min(height[lp], height[rp]);
            int area = w*h;
            Maxwater = Math.max( Maxwater , area);

            if (height[lp] < height[rp]){
                lp++;
            }
            else{
                rp--;
            }
        }
    return Maxwater;
    }
}
