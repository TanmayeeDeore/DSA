public class pattern1 {
    public static void main(String[] args) {
        for (int i=1; i<=5; i++)  { //this is for the outer loop and limited till number of lines
            for(int j=1 ;  j<=i ;j++ )  {//this is the inner loop this will print no of star in each line according to the number of limes
                System.out.print("*");
               // j++;

            }//till here the loop will print the star in a single line 
            
            System.out.println();//this is to bring new line after each loop

        }

        for(int i=0 ; i<=5 ;i++){
            for(int j=0 ; j<i ; j++){
                System.out.print(i);
            }
            System.out.println();
        }
        
        System.out.println("inverted pattern");
        for(int i=1; i<=5 ; i++){//this is for the outer loop and limited till number of lines
            for(int j=1 ; j<=5-i+1 ;j++){//this is the inner loop this will print no of star in each line according to the number of limes
                System.out.print("*");
            }
            System.out.println();
        }


       

    }
    
}
