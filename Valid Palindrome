class Solution {
    public boolean isPalindrome(String s) {
       StringBuilder sb = new StringBuilder(); //use a stringbuilder
       for(int i =0 ; i<s.length() ; i++){ //iterate for each charecter
            char currChar = s.charAt(i); //store each char in currchar variable
            //if the chararter is alphabetic then store in the sb and convert to lowercase
            if (Character.isLetterOrDigit(currChar)){
                sb.append(Character.toLowerCase(currChar));
            }
       }
       int st=0;
       int en=sb.length()-1;
       while(st<en){
        if(sb.charAt(st) != sb.charAt(en)){
            return false;
        }
        st++;
        en--;

       }
    return true;
    }
}
